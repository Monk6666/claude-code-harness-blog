<div class="arch-wrapper">

  <!-- Top: Query Loop -->
  <div class="arch-top">
    <span class="en">Query Loop</span>
    <span class="zh">主迴圈 / 串流工具執行</span>
  </div>

  <!-- Middle: 5 subsystems -->
  <div class="arch-mid">
    <div class="cell">
      <span class="en">Tool System</span>
      <span class="zh">工具定義・驗證執行</span>
    </div>
    <div class="cell">
      <span class="en">Agent Orchestration</span>
      <span class="zh">代理編排・Cache 共享</span>
    </div>
    <div class="cell">
      <span class="en">Permission System</span>
      <span class="zh">分層權限・ML 分類器</span>
    </div>
    <div class="cell">
      <span class="en">Hook System</span>
      <span class="zh">生命週期・擴展點</span>
    </div>
    <div class="cell cell-last-mid">
      <span class="en">Context Mgmt</span>
      <span class="zh">上下文・快取壓縮</span>
    </div>
  </div>

  <!-- Bottom: 4 subsystems -->
  <div class="arch-bot">
    <div class="cell cell-dim">
      <span class="en">Skills</span>
      <span class="zh">技能</span>
    </div>
    <div class="cell cell-dim">
      <span class="en">Plugins / MCP</span>
      <span class="zh">插件・協議</span>
    </div>
    <div class="cell cell-dim">
      <span class="en">State Mgmt</span>
      <span class="zh">狀態管理</span>
    </div>
    <div class="cell cell-dim">
      <span class="en">Task System</span>
      <span class="zh">任務系統</span>
    </div>
  </div>

</div>

<style>
  /* ── Outer shell ─────────────────────────────── */
  .arch-wrapper {
    border: 1.5px solid var(--sl-color-gray-4);
    border-radius: 10px;
    overflow: hidden;
    margin: 1.5rem 0;
    font-family: var(--sl-font-system);
  }

  /* ── Top banner ──────────────────────────────── */
  .arch-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 14px 16px;
    text-align: center;
    background: var(--sl-color-accent-low);
    border-bottom: 1.5px solid var(--sl-color-gray-4);
  }
  .arch-top .en {
    font-size: 1rem;
    font-weight: 800;
    color: var(--sl-color-accent);
  }
  .arch-top .zh {
    font-size: 0.8rem;
    color: var(--sl-color-accent);
    opacity: 0.85;
  }

  /* ── Grid sections ───────────────────────────── */
  /*
   * Gap trick: set gap=1px + background=border-color on the grid,
   * and background=page-bg on each cell.
   * This renders 1px dividers in every direction automatically —
   * no border-right / nth-child hacks, works when rows wrap.
   */
  .arch-mid,
  .arch-bot {
    display: grid;
    gap: 1px;
    background: var(--sl-color-gray-4); /* gap colour = divider */
    border-bottom: 1.5px solid var(--sl-color-gray-4);
  }
  .arch-bot {
    border-bottom: none;
  }

  /* Desktop: 5 / 4 columns */
  .arch-mid { grid-template-columns: repeat(5, 1fr); }
  .arch-bot { grid-template-columns: repeat(4, 1fr); }

  /* ── Cells ───────────────────────────────────── */
  .cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 14px 10px;
    text-align: center;
    background: var(--sl-color-bg);
  }
  .cell-dim {
    background: var(--sl-color-gray-7, #f4f4f5);
  }

  .en {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--sl-color-text);
    word-break: break-word;
  }
  .zh {
    font-size: 0.72rem;
    color: var(--sl-color-gray-2);
    word-break: break-word;
  }

  /* ── Tablet: 2-col wrap ──────────────────────── */
  @media (max-width: 720px) {
    .arch-mid { grid-template-columns: repeat(2, 1fr); }
    .arch-bot { grid-template-columns: repeat(2, 1fr); }

    /* 5th cell spans both columns so the row is balanced */
    .arch-mid .cell-last-mid {
      grid-column: 1 / -1;
    }
  }

  /* ── Mobile: tighten padding & font ─────────── */
  @media (max-width: 480px) {
    .en { font-size: 0.75rem; }
    .zh { font-size: 0.65rem; }
    .cell { padding: 10px 8px; }
    .arch-top .en { font-size: 0.9rem; }
    .arch-top .zh { font-size: 0.75rem; }
  }

  /* ── Dark mode ───────────────────────────────── */
  :root[data-theme='dark'] .cell-dim {
    background: var(--sl-color-gray-6, #1e2025);
  }
</style>
